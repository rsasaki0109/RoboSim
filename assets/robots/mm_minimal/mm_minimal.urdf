<?xml version="1.0"?>
<robot name="mm_minimal">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.6 0.4"/>
      </geometry>
    </visual>
    <!-- Collision box is shorter than the visual chassis and shifted down: the
         shoulder pivot sits at +0.3 and the upper-arm collision box (0.08 tall)
         reaches down to +0.26, so a full-height chassis collider interpenetrates
         the arm and contact impulses lock the shoulder joint solid. -->
    <collision>
      <origin xyz="0 -0.05 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.5 0.4"/>
      </geometry>
    </collision>
  </link>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.25 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.08 0.08"/>
      </geometry>
    </visual>
    <!-- Collision boxes along the arm chain are slightly shorter than the visuals
         so adjacent links do not interpenetrate: overlapping colliders on jointed
         links generate contact impulses that lock the joint solid. -->
    <collision>
      <origin xyz="0.24 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.46 0.08 0.08"/>
      </geometry>
    </collision>
  </link>

  <link name="forearm_link">
    <visual>
      <origin xyz="0.2 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.06 0.06"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.18 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.34 0.06 0.06"/>
      </geometry>
    </collision>
  </link>

  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.04 0.04"/>
      </geometry>
    </visual>
    <!-- Collision is a token box, much smaller than the visual: this mount sits at
         the same X/Y/Z as a graspable object between the flanking fingers
         (half-extent up to ~0.035 m — wider than this mount at any collision size
         that still resembles the visual), so a full-size collider here
         interpenetrates the object before the fingers can close around it and
         ejects it out of reach; contact with the mount (not a finger) also doesn't
         count toward the grasp weld, so a collider here can only hurt, never help,
         a grasp. It still needs *some* collision geometry to spawn as a rigid body
         (the fingers are its joint children), hence the token size instead of none.
    -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.005 0.005 0.005"/>
      </geometry>
    </collision>
  </link>

  <link name="left_finger_link">
    <!-- Visual is shifted +0.04 forward (local X) of the collision box: the finger
         joints are offset from gripper_base_link only laterally (Z), so the
         unmodified visual sits flush at the forearm tip while the weld-anchor
         computed in sim.rs (canonical_grasp_anchor) now gives the grasped object a
         forward standoff, leaving the rendered pads floating behind the held
         object. Shifting only the visual keeps grasp contact geometry (and thus
         grasp physics) exactly where it was. -->
    <visual>
      <origin xyz="0.04 0 -0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.08"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.08"/>
      </geometry>
    </collision>
  </link>

  <link name="right_finger_link">
    <!-- See left_finger_link: visual-only forward shift to meet the grasp
         weld-anchor's new forward standoff; collision left untouched. -->
    <visual>
      <origin xyz="0.04 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.08"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.08"/>
      </geometry>
    </collision>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.5 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="forearm_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0.4 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="left_finger_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="left_finger_link"/>
    <origin xyz="0 0 -0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_finger_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="right_finger_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
</robot>
