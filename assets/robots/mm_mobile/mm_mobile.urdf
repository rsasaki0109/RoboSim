<?xml version="1.0"?>
<robot name="mm_mobile">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.3 0.4"/>
      </geometry>
      <material name="hero_blue">
        <color rgba="0.16 0.38 0.72 1.0"/>
      </material>
    </visual>
    <!-- Collision box is shorter than the visual chassis and shifted down: the
         shoulder pivot sits at +0.15 and the upper-arm collision box (0.08 tall)
         reaches down to +0.11, so a full-height chassis collider interpenetrates
         the arm and contact impulses lock the shoulder joint solid. -->
    <collision>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.2 0.4"/>
      </geometry>
    </collision>
  </link>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="wheel_black">
        <color rgba="0.08 0.08 0.08 1.0"/>
      </material>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="wheel_black">
        <color rgba="0.08 0.08 0.08 1.0"/>
      </material>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.25 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.07 0.07"/>
      </geometry>
      <material name="hero_arm"><color rgba="0.90 0.42 0.12 1.0"/></material>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.065" length="0.10"/></geometry>
      <material name="hero_joint"><color rgba="0.16 0.18 0.22 1.0"/></material>
    </visual>
    <!-- Collision boxes along the arm chain are slightly shorter than the visuals
         so adjacent links do not interpenetrate: overlapping colliders on jointed
         links generate contact impulses that lock the joint solid. -->
    <collision>
      <origin xyz="0.24 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.46 0.08 0.08"/>
      </geometry>
    </collision>
  </link>

  <link name="forearm_link">
    <visual>
      <origin xyz="0.2 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.055 0.055"/>
      </geometry>
      <material name="hero_arm"><color rgba="0.90 0.42 0.12 1.0"/></material>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.085"/></geometry>
      <material name="hero_joint"><color rgba="0.16 0.18 0.22 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.18 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.34 0.06 0.06"/>
      </geometry>
    </collision>
  </link>

  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.07 0.09"/>
      </geometry>
      <material name="hero_shell"><color rgba="0.72 0.76 0.82 1.0"/></material>
    </visual>
    <visual>
      <origin xyz="-0.035 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.045" length="0.075"/></geometry>
      <material name="hero_joint"><color rgba="0.16 0.18 0.22 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.04 0.04"/>
      </geometry>
    </collision>
  </link>

  <link name="left_finger_link">
    <!-- Visual is shifted +0.04 forward (local X) of the collision box: the finger
         joints are offset from gripper_base_link only laterally (Z), so the
         unmodified visual sits flush at the forearm tip while the weld-anchor
         computed in sim.rs (canonical_grasp_anchor) now gives the grasped object a
         forward standoff, leaving the rendered pads floating behind the held
         object. Shifting only the visual keeps grasp contact geometry (and thus
         grasp physics) exactly where it was. -->
    <visual>
      <origin xyz="0.04 0 -0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.08"/>
      </geometry>
      <material name="hero_gripper"><color rgba="0.10 0.12 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.08"/>
      </geometry>
    </collision>
  </link>

  <link name="right_finger_link">
    <!-- See left_finger_link: visual-only forward shift to meet the grasp
         weld-anchor's new forward standoff; collision left untouched. -->
    <visual>
      <origin xyz="0.04 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.08"/>
      </geometry>
      <material name="hero_gripper"><color rgba="0.10 0.12 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.08"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 -0.15 0.225" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.15 -0.225" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="shoulder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0.15 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.5 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="forearm_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0.4 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="left_finger_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="left_finger_link"/>
    <origin xyz="0 0 -0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_finger_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="right_finger_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
</robot>
